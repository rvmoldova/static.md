{
  "name": "static-firebase",
  "version": "1.0.0",
  "private": true,
  "description": "Static.md — Firebase hosting + functions + frontend",
  "scripts": {
    "dev": "vite",
    "build:frontend": "vite build",
    "build:functions": "cd functions && npm run build",
    "build": "npm run build:frontend && npm run build:functions",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy",
    "deploy:functions": "npm run build:functions && firebase deploy --only functions",
    "deploy:hosting": "npm run build:frontend && firebase deploy --only hosting"
  },
  "dependencies": {
    "imagesloaded": "^5.0.0",
    "masonry-layout": "^4.2.2",
    "photoswipe": "^5.4.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "sass": "^1.83.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  }
}
